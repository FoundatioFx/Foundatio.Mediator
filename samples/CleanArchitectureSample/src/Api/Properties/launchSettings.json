{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "Api": {
      "commandName": "Project",
      "launchBrowser": true,
      "commandLineArgs": "--mode api",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "Worker": {
      "commandName": "Project",
      "commandLineArgs": "--mode worker",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "Worker-Exports": {
      "commandName": "Project",
      "commandLineArgs": "--mode worker --queues exports",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  }
}
